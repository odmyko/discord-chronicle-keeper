DISCORD_BOT_TOKEN=put_token_here

# Whisper ASR webservice (onerahmet/openai-whisper-asr-webservice)
WHISPER_BASE_URL=http://127.0.0.1:9000
WHISPER_ASR_PATH=/asr
WHISPER_LANGUAGE=ru
WHISPER_TASK=transcribe
WHISPER_ENCODE=true

# Whisper container runtime options (docker-compose whisper service)
# Engine: openai_whisper | faster_whisper
WHISPER_ASR_ENGINE=faster_whisper
# Standard: tiny, base, small, medium, large-v1, large-v2, large-v3 (large), large-v3-turbo (turbo)
# English: tiny.en, base.en, small.en, medium.en
# Distilled (faster-whisper/whisperx): distil-large-v2, distil-medium.en, distil-small.en, distil-large-v3
WHISPER_ASR_MODEL=large-v3-turbo
# Path inside container where models are cached / mounted
WHISPER_ASR_MODEL_PATH=/models/whisper

# LM Studio OpenAI-compatible API
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_TEMPERATURE=0.2
LMSTUDIO_MAX_TOKENS=1400
# Max post-processing time per session (transcription + summary pipeline).
PROCESSING_TIMEOUT_SECONDS=7200
# Chunk size for long-session summarization pipeline.
# Large transcripts are summarized in chunks and then combined.
SUMMARY_CHUNK_CHARS=14000
# Auto-rotate recording segment every N seconds (1800 = 30 min, 0 = disabled).
RECORDING_ROTATION_SECONDS=1800
# On bot startup, post available artifacts for unfinished sessions (best effort).
RECOVERY_AUTO_POST_PARTIAL=true
# Max unfinished sessions to auto-post per startup.
RECOVERY_MAX_SESSIONS=20
# Auto-cleanup old session artifacts.
AUTO_CLEANUP_ENABLED=false
# Run cleanup at bot startup.
AUTO_CLEANUP_ON_START=false
# Remove sessions older than N days.
RETENTION_DAYS=30
# Allow destructive purge slash commands.
ALLOW_PURGE_COMMANDS=false

# Optional audio preprocessing before Whisper (default: false)
# Applies a mild high-pass + loudness normalization and then saves MP3.
AUDIO_NORMALIZE=false

# Optional generic aliases (used by Docker Compose models injection)
# LLM_BASE_URL=http://127.0.0.1:1234/v1
# LLM_MODEL=local-model

# Storage
DATA_DIR=./data
