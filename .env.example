## BASIC (edit these first)

DISCORD_BOT_TOKEN=put_token_here

# ASR backend:
# - qwen3_asr: local Python Qwen3-ASR inference
# - vibevoice_asr: separate .venv-vibe subprocess with VibeVoice-ASR
ASR_BACKEND=qwen3_asr

# Generic OpenAI-compatible LLM endpoint used by bot runtime.
# Local Python run with LM Studio: usually http://127.0.0.1:1234/v1
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=local-model

# Shared ASR defaults used by all backends.
ASR_LANGUAGE=ru
ASR_DTYPE=float16
ASR_MAX_NEW_TOKENS=4096

# Recording auto-rotation (900 = 15 min, 0 = disabled).
RECORDING_ROTATION_SECONDS=900

# Artifacts root.
DATA_DIR=./data


## RECOMMENDED DEFAULTS (usually keep as-is)

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1400
# Target length for "Player-Facing Chronicle Post" section.
LLM_CHRONICLE_MIN_WORDS=180
LLM_CHRONICLE_MAX_WORDS=320

PROCESSING_TIMEOUT_SECONDS=7200
VOICE_PATCH_MODE=legacy
# Optional: route start/stop control to Node voice sidecar API.
VOICE_SIDECAR_ENABLED=false
VOICE_SIDECAR_BASE_URL=http://127.0.0.1:8081
VOICE_SIDECAR_TIMEOUT_SECONDS=30
# If true, sidecar mode runs incremental ASR after each rotation chunk.
LIVE_CHUNK_TRANSCRIBE_ON_ROTATION=false
# Shared token for sidecar API auth (maps to sidecar SIDECAR_TOKEN).
SIDECAR_TOKEN=
# Voice sidecar DAVE/E2EE tuning.
SIDECAR_DAVE_ENCRYPTION=true
SIDECAR_DECRYPTION_FAILURE_TOLERANCE=10

LLM_WARMUP_ON_START=false


## QWEN3-ASR

QWEN3_ASR_MODEL=Qwen/Qwen3-ASR-1.7B
# Optional override (fallback: ASR_DTYPE)
QWEN3_ASR_DTYPE=
# transformers attention backend: auto | eager | sdpa | flash_attention_2
QWEN3_ASR_ATTN_IMPLEMENTATION=auto
# Optional override (fallback: ASR_MAX_NEW_TOKENS)
QWEN3_ASR_MAX_NEW_TOKENS=
QWEN3_ASR_MAX_INFERENCE_BATCH_SIZE=32
QWEN3_ASR_WARMUP_ON_START=false


## VIBEVOICE-ASR (separate env)

# Python interpreter in dedicated VibeVoice env.
VIBEVOICE_PYTHON=.\.venv-vibe\Scripts\python.exe
# Script used by runtime client.
VIBEVOICE_SCRIPT=scripts/test_vibevoice_asr.py
VIBEVOICE_MODEL=microsoft/VibeVoice-ASR-HF
# Optional override (fallback: ASR_DTYPE)
VIBEVOICE_DTYPE=
# Optional override (fallback: ASR_MAX_NEW_TOKENS)
VIBEVOICE_MAX_NEW_TOKENS=
VIBEVOICE_WARMUP_ON_START=false


## DOCKER/COMPOSE OVERRIDES

# If you run Docker model runner manually (outside compose `models:`), typical host endpoint is:
# LLM_BASE_URL=http://127.0.0.1:12434/engines/v1
# LLM_MODEL=ai/gpt-oss:20B-MXFP4

# Optional GPU build args for `bot_sidecar_gpu` profile.
# Keep defaults unless you need a specific torch/cuda wheel.
TORCH_VERSION=2.8.0
TORCH_WHL_INDEX_URL=https://download.pytorch.org/whl/cu129


## LM STUDIO AUTO-LOAD (optional)

# If endpoint returns "No models loaded", bot can request LM Studio to load model once.
LMSTUDIO_AUTO_LOAD=false

# Optional explicit control API base URL (without trailing slash).
# If empty, derived from LLM_BASE_URL by stripping /v1.
LMSTUDIO_CONTROL_BASE_URL=
LMSTUDIO_CONTROL_LOAD_PATH=/api/v1/models/load
LMSTUDIO_CONTROL_TIMEOUT_SECONDS=180
LMSTUDIO_AUTO_LOAD_WAIT_SECONDS=1.5


## SUMMARY CONTEXT GATE (optional)

# If enabled, bot checks transcript relevance to campaign context/hints and
# can summarize without context when conversation is off-topic.
SUMMARY_CONTEXT_RELEVANCE_GATE=false
SUMMARY_CONTEXT_MIN_RELEVANCE=0.40


## AUDIO PIPELINE TUNING (optional)

# Dual pass:
# - timeline from raw audio (no VAD/normalize)
# - text from processed audio
# Recommended for long tabletop/RPG sessions.
AUDIO_DUAL_PIPELINE_ENABLED=true

# Mild high-pass + loudness normalization before ASR.
# Recommended for multi-hour voice sessions.
AUDIO_NORMALIZE=true

# Trim long silence before ASR (conservative).
AUDIO_VAD_ENABLED=false

# MP3 output profile (0=best quality/largest, 9=smallest/lower quality).
AUDIO_MP3_VBR_QUALITY=4
# 0 = keep source value.
# Recommended speech profile: mono @ 16kHz.
AUDIO_TARGET_CHANNELS=1
AUDIO_TARGET_SAMPLE_RATE=16000

# Publish per-speaker audio tracks in addition to mixed_session.mp3.
PUBLISH_PER_SPEAKER_AUDIO=false


## RECOVERY / RETENTION / SAFETY

RECOVERY_AUTO_POST_PARTIAL=true
RECOVERY_MAX_SESSIONS=20

AUTO_CLEANUP_ENABLED=false
AUTO_CLEANUP_ON_START=false
RETENTION_DAYS=30
ALLOW_PURGE_COMMANDS=false


## VOICE RECEIVE BURST GUARD

VOICE_DECODE_BURST_WINDOW_SECONDS=15
VOICE_DECODE_BURST_THRESHOLD=8
VOICE_DECODE_BURST_COOLDOWN_SECONDS=60
