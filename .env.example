## BASIC (edit these first)

DISCORD_BOT_TOKEN=put_token_here

# Whisper endpoint used by bot runtime.
# Local Python run: usually http://127.0.0.1:9000
# Docker compose default bot: uses BOT_WHISPER_BASE_URL below.
WHISPER_BASE_URL=http://127.0.0.1:9000

# Generic OpenAI-compatible LLM endpoint used by bot runtime.
# Local Python run with LM Studio: usually http://127.0.0.1:1234/v1
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=local-model

# Default summary language.
WHISPER_LANGUAGE=ru

# Recording auto-rotation (1800 = 30 min, 0 = disabled).
RECORDING_ROTATION_SECONDS=1800

# Artifacts root.
DATA_DIR=./data


## RECOMMENDED DEFAULTS (usually keep as-is)

WHISPER_API_STYLE=asr
WHISPER_ASR_PATH=/asr
WHISPER_TASK=transcribe
WHISPER_ENCODE=true

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1400

PROCESSING_TIMEOUT_SECONDS=7200
SUMMARY_CHUNK_CHARS=14000

WHISPER_WARMUP_ON_START=false
LLM_WARMUP_ON_START=false


## DOCKER/COMPOSE OVERRIDES

# Bot-side ASR endpoint inside compose network.
# asr profile default:
BOT_WHISPER_BASE_URL=http://whisper:9000
# vLLM profile example:
# BOT_WHISPER_BASE_URL=http://whisper_vllm:8000

# Optional token for vLLM image/model pulls from Hugging Face.
HUGGING_FACE_HUB_TOKEN=

# Whisper container runtime options (compose whisper service)
# Engine: openai_whisper | faster_whisper
WHISPER_ASR_ENGINE=faster_whisper
# Standard: tiny, base, small, medium, large-v1, large-v2, large-v3 (large), large-v3-turbo (turbo)
# English: tiny.en, base.en, small.en, medium.en
# Distilled (faster-whisper/whisperx): distil-large-v2, distil-medium.en, distil-small.en, distil-large-v3
WHISPER_ASR_MODEL=large-v3-turbo
WHISPER_ASR_MODEL_PATH=/models/whisper

# If you run Docker model runner manually (outside compose `models:`), typical host endpoint is:
# LLM_BASE_URL=http://127.0.0.1:12434/engines/v1
# LLM_MODEL=ai/gpt-oss:20B-MXFP4


## ASR OPENAI-STYLE OPTIONS (used when WHISPER_API_STYLE=openai)

WHISPER_OPENAI_MODEL=openai/whisper-large-v3-turbo
# 0.0 = deterministic decoding (recommended for stable transcripts).
WHISPER_OPENAI_TEMPERATURE=0.0
# Optional names/lore hint for ASR.
WHISPER_OPENAI_PROMPT=


## LM STUDIO AUTO-LOAD (optional)

# If endpoint returns "No models loaded", bot can request LM Studio to load model once.
LMSTUDIO_AUTO_LOAD=false

# Optional explicit control API base URL (without trailing slash).
# If empty, derived from LLM_BASE_URL by stripping /v1.
LMSTUDIO_CONTROL_BASE_URL=
LMSTUDIO_CONTROL_LOAD_PATH=/api/v1/models/load
LMSTUDIO_CONTROL_TIMEOUT_SECONDS=180
LMSTUDIO_AUTO_LOAD_WAIT_SECONDS=1.5


## WHISPER FALLBACK (optional)

# Retry via secondary ASR endpoint when primary fails.
WHISPER_FALLBACK_ENABLED=false
WHISPER_FALLBACK_BASE_URL=
# Optional override style/path/model for fallback.
# If empty, style defaults to WHISPER_API_STYLE and model defaults to WHISPER_OPENAI_MODEL.
WHISPER_FALLBACK_API_STYLE=
WHISPER_FALLBACK_ASR_PATH=
WHISPER_FALLBACK_OPENAI_MODEL=

# Optional fallback trigger on weak transcript quality.
WHISPER_FALLBACK_ON_LOW_QUALITY=false
WHISPER_LOW_QUALITY_MIN_CHARS=40
WHISPER_LOW_QUALITY_MIN_SEGMENTS=1


## SUMMARY CONTEXT GATE (optional)

# If enabled, bot checks transcript relevance to campaign context/hints and
# can summarize without context when conversation is off-topic.
SUMMARY_CONTEXT_RELEVANCE_GATE=false
SUMMARY_CONTEXT_MIN_RELEVANCE=0.40


## AUDIO PIPELINE TUNING (optional)

# Dual pass:
# - timeline from raw audio (no VAD/normalize)
# - text from processed audio
# Recommended for long tabletop/RPG sessions.
AUDIO_DUAL_PIPELINE_ENABLED=true

# Mild high-pass + loudness normalization before Whisper.
# Recommended for multi-hour voice sessions.
AUDIO_NORMALIZE=true

# Trim long silence before Whisper (conservative).
AUDIO_VAD_ENABLED=false

# MP3 output profile (0=best quality/largest, 9=smallest/lower quality).
AUDIO_MP3_VBR_QUALITY=4
# 0 = keep source value.
# Recommended speech profile: mono @ 16kHz.
AUDIO_TARGET_CHANNELS=1
AUDIO_TARGET_SAMPLE_RATE=16000

# Publish per-speaker audio tracks in addition to mixed_session.mp3.
PUBLISH_PER_SPEAKER_AUDIO=false


## RECOVERY / RETENTION / SAFETY

RECOVERY_AUTO_POST_PARTIAL=true
RECOVERY_MAX_SESSIONS=20

AUTO_CLEANUP_ENABLED=false
AUTO_CLEANUP_ON_START=false
RETENTION_DAYS=30
ALLOW_PURGE_COMMANDS=false


## VOICE RECEIVE BURST GUARD

VOICE_DECODE_BURST_WINDOW_SECONDS=15
VOICE_DECODE_BURST_THRESHOLD=8
VOICE_DECODE_BURST_COOLDOWN_SECONDS=60
